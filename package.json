{
  "name": "@beomjk/emdd",
  "version": "0.1.13",
  "description": "CLI for Evolving Mindmap-Driven Development",
  "type": "module",
  "bin": {
    "emdd": "dist/cli.js",
    "emdd-mcp": "dist/mcp-server/cli.js"
  },
  "files": [
    "dist/",
    "dist/web/",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "scripts": {
    "gen:schema": "tsx src/schema/codegen.ts",
    "gen:spec-tables": "tsx src/schema/spec-tables.ts",
    "build": "npm run gen:schema && tsc && cp src/rules/*.md dist/rules/ && npm run build:web",
    "build:web": "tsx scripts/build-web.ts",
    "dev": "tsx src/cli.ts",
    "test": "vitest",
    "test:run": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "spec:coverage": "tsx src/schema/spec-coverage.ts",
    "demo:record": "npx terminal-demo play docs/assets/demo.md --prompt '' --record docs/assets/demo.cast && npx svg-term-cli --in docs/assets/demo.cast --out docs/assets/demo.svg --window --width 80 --height 24"
  },
  "keywords": [
    "emdd",
    "mindmap",
    "research",
    "knowledge-graph",
    "cli"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "cytoscape": "^3.33.1",
    "cytoscape-dagre": "^2.5.0",
    "cytoscape-fcose": "^2.2.0",
    "glob": "^13.0.6",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-components": "^1.5.4",
    "graphology-traversal": "^0.3.1",
    "graphology-types": "^0.24.8",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.8",
    "js-yaml": "^4.1.1",
    "open": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.27.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
