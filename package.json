{
  "name": "@beomjk/emdd",
  "version": "0.1.29",
  "description": "CLI for Evolving Mindmap-Driven Development",
  "type": "module",
  "bin": {
    "emdd": "dist/cli.js",
    "emdd-mcp": "dist/mcp-server/cli.js"
  },
  "files": [
    "dist/",
    "dist/web/",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schema": {
      "import": "./dist/schema/schema.config.js",
      "types": "./dist/schema/schema.config.d.ts"
    }
  },
  "scripts": {
    "gen:spec-tables": "tsx src/schema/spec-tables.ts",
    "gen:doc-tables": "tsx src/schema/doc-tables.ts",
    "gen:tables": "npm run gen:spec-tables && npm run gen:doc-tables",
    "build": "tsc && cp src/rules/*.md dist/rules/ && npm run build:web",
    "build:web": "vite build",
    "dev": "tsx src/cli.ts",
    "dev:web": "vite dev --config vite.config.ts",
    "test": "vitest",
    "test:run": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "tsc --noEmit && svelte-check --tsconfig ./src/web/frontend/tsconfig.json",
    "svelte-check": "svelte-check --tsconfig ./src/web/frontend/tsconfig.json",
    "spec:coverage": "tsx src/schema/spec-coverage.ts",
    "demo:svg": "tsx scripts/generate-demo-svg.ts"
  },
  "keywords": [
    "emdd",
    "mindmap",
    "research",
    "knowledge-graph",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@beomjk/state-engine": "^0.1.4",
    "@hono/node-server": "^1.19.11",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "cytoscape": "^3.33.1",
    "cytoscape-dagre": "^2.5.0",
    "cytoscape-fcose": "^2.2.0",
    "glob": "^13.0.6",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-components": "^1.5.4",
    "graphology-traversal": "^0.3.1",
    "graphology-types": "^0.24.8",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.8",
    "js-yaml": "^4.1.1",
    "open": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^29.0.2",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "tsx": "^4.21.0",
    "vite": "^8.0.8",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
