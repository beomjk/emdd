{
  "name": "@beomjk/emdd",
  "version": "0.1.3",
  "description": "CLI for Evolving Mindmap-Driven Development",
  "type": "module",
  "bin": {
    "emdd": "dist/cli.js",
    "emdd-mcp": "dist/mcp-server/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "scripts": {
    "gen:schema": "tsx src/schema/codegen.ts",
    "gen:spec-tables": "tsx src/schema/spec-tables.ts",
    "build": "npm run gen:schema && tsc && cp src/rules/*.md dist/rules/",
    "dev": "tsx src/cli.ts",
    "test": "vitest",
    "test:run": "vitest run --passWithNoTests",
    "lint": "tsc --noEmit",
    "spec:coverage": "tsx src/schema/spec-coverage.ts",
    "demo:record": "npx terminal-demo play docs/assets/demo.md --record docs/assets/demo.cast && npx svg-term --in docs/assets/demo.cast --out docs/assets/demo.svg --window --width 80 --height 24"
  },
  "keywords": [
    "emdd",
    "mindmap",
    "research",
    "knowledge-graph",
    "cli"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
